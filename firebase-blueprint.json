{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A message in the group chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "message": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "senderRole", "timestamp"]
    }
  },
  "firestore": {
    "/messages": {
      "schema": "Message",
      "description": "All chat messages for the global group"
    }
  }
}
